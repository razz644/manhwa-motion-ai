# This app runs 100% in local demo mode using localStorage.
# No environment variables are required to run (procedural previews always work).

# === REAL VIDEO PROVIDERS ===
# Kling AI (recommended starting point)
# 1. Create keys at https://kling.ai → Developer/API
# 2. Generate JWT API Token from your Access Key + Secret (see their auth docs)
# 3. Paste the token below
# KLING_API_TOKEN=your-jwt-token-here

# Other providers (future)
# VEO3_API_KEY=
# RUNWAY_API_KEY=
# PIXVERSE_API_KEY=
# LUMA_API_KEY=
# HAILUO_API_KEY=

# For future custom LoRA training backend (placeholder)
# TRAINING_API_ENDPOINT=
